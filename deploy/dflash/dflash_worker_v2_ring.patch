+    def _ring_slots_2d(
+        self, req_pool_indices: torch.Tensor, positions_2d: torch.Tensor
+    ) -> torch.Tensor:
+        """Ring KV slot for each [bs, k] global position:
+            slot = req_pool_idx * draft_ring_size + (global_pos % draft_ring_size)
+        Out-of-window positions reuse (overwrite) the slot of the token
+        draft_ring_size positions earlier; no allocation, no free-list.
+        """
+        R = int(self.draft_ring_size)
+        req = req_pool_indices.to(torch.int64)
+        # Defensive: keep the region index in range even if req_pool_idx ever
+        # exceeds the provisioned region count (would only cause two requests to
+        # share a ring region -> degraded draft acceptance, never an OOB crash or
+        # a wrong emitted token, since DFlash is lossless). With the default 4x
+        # quota this modulo is a no-op in practice.
+        nregions = getattr(self, "_draft_ring_num_req_slots", None)
+        if nregions:
+            req = req % int(nregions)
+        base = req.view(-1, 1) * R
+        return base + (positions_2d.to(torch.int64) % R)
+
+    def _ring_slots_segments(
+        self,
+        *,
+        req_pool_indices: torch.Tensor,
+        start: torch.Tensor | None,
+        lengths: torch.Tensor,
+    ) -> torch.Tensor:
+        """Ring-slot analogue of _gather_req_to_token_segments: a flattened,
+        mask-packed 1D tensor of ring slots for the window suffix [start, start+len)
+        of each request. Same output shape/ordering as the gather it replaces."""
+        lengths = lengths.to(torch.int64)
+        if lengths.numel() == 0:
+            return torch.empty((0,), dtype=torch.int64, device=self.device)
+        max_len = int(lengths.max().item())
+        if max_len <= 0:
+            return torch.empty((0,), dtype=torch.int64, device=self.device)
+        req_pool_indices = req_pool_indices.to(torch.int64)
+        offsets = torch.arange(
+            max_len, device=self.device, dtype=torch.int64
+        ).unsqueeze(0)
+        if start is None:
+            pos2d = offsets.expand(req_pool_indices.shape[0], -1)
+        else:
+            pos2d = start.to(torch.int64).unsqueeze(1) + offsets
+        mask = offsets < lengths.unsqueeze(1)
+        slots = self._ring_slots_2d(req_pool_indices, pos2d)
+        return slots[mask].to(torch.int64)
+
